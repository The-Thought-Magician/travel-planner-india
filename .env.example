# Environment Variables
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite:///./data/travel_planner.db

# Cache (Redis - optional for MVP)
# REDIS_URL=redis://localhost:6379/0

# External APIs (for future use)
# AVIATIONSTACK_API_KEY=
# INDIANRAILAPI_KEY=

# Scraping Settings
SCRAPER_USER_AGENT="Mozilla/5.0 (compatible; TravelPlanner-Bot/1.0; +https://github.com/travel-planner)"
SCRAPER_DELAY_MIN=1
SCRAPER_DELAY_MAX=3
SCRAPER_TIMEOUT=30

# Routing Settings
MAX_CONNECTIONS=3
MIN_CONNECTION_BUFFER_MINUTES=60
MAX_JOURNEY_HOURS=48

# Top N cities for MVP
TOP_N_CITIES=50
