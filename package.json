{
  "name": "travel-planner-india",
  "version": "1.0.0",
  "description": "Multi-modal journey planner for India",
  "scripts": {
    "backend": "uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "frontend": "pnpm -C frontend dev",
    "dev": "bash run-all.sh",
    "install:all": "uv sync && pnpm -C frontend install",
    "test": "uv run pytest"
  }
}
